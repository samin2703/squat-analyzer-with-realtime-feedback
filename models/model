# 1. BASE MODEL
FROM ./squat.gguf

# 2. THE TEMPLATE (Minimalist - strictly matches your Unsloth training)
TEMPLATE """<|begin_of_text|><|start_header_id|>system<|end_header_id|>

{{ .System }}<|eot_id|><|start_header_id|>user<|end_header_id|>

Instruction: You are a concise squat coach. Given spine, knee, and ankle conditions (0-1), Big Five personality traits (0-1), and a list of issues, identify the priority area and give 1-2 short cues. Max 18 words.
Input Data: {{ .Prompt }}<|eot_id|><|start_header_id|>assistant<|end_header_id|>
"""

# 3. THE SYSTEM PROMPT (Generic instruction only)
SYSTEM """You are a concise squat coach. Provide coaching cues based on the provided sensor data and personality traits."""

# 4. PARAMETERS (Allowing the fine-tuned brain to work)
PARAMETER temperature 0.3
PARAMETER top_p 0.9
PARAMETER repeat_penalty 1.2
PARAMETER stop "<|eot_id|>"
PARAMETER stop "<|start_header_id|>"
PARAMETER stop "<|end_header_id|>"
